{
  "name": "acontplus-libs",
  "version": "1.0.0",
  "scripts": {
    "start": "nx serve demo-app --ssl true --hmr",
    "start:erp": "nx serve acontplus-erp --ssl true --hmr --port 4300",
    "build": "nx build demo-app",
    "watch": "nx build demo-app --watch --configuration development",
    "build:all": "nx run-many --target=build --all",
    "build:libs": "nx run-many --target=build --projects=core,ng-auth,ng-components,ng-customer,ng-infrastructure,ng-notifications,ui-kit,utils,ng-common",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write \"**/*.{ts,js,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,html,css,scss,json,md}\"",
    "format:fix": "pnpm run format",
    "lint:all": "pnpm run lint && pnpm run format:check",
    "clean": "nx reset",
    "local-registry": "nx run acontplus-libs:local-registry",
    "e2e": "nx run demo-app-e2e:e2e",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@acontplus/core": "workspace:^",
    "@acontplus/ng-auth": "workspace:^",
    "@acontplus/ng-common": "workspace:^",
    "@acontplus/ng-components": "workspace:^",
    "@acontplus/ng-config": "workspace:^",
    "@acontplus/ng-customer": "workspace:^",
    "@acontplus/ng-infrastructure": "workspace:^",
    "@acontplus/ng-notifications": "workspace:^",
    "@acontplus/ui-kit": "workspace:^",
    "@acontplus/utils": "workspace:^",
    "@angular/animations": "22.0.2",
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/platform-browser-dynamic": "22.0.2",
    "@angular/platform-server": "22.0.2",
    "@angular/router": "22.0.2",
    "@angular/ssr": "22.0.2",
    "@formkit/tempo": "1.0.0",
    "@jsverse/transloco": "^8.2.1",
    "@ng-select/ng-select": "23.0.1",
    "bootstrap": "^5.3.8",
    "decimal.js": "^10.6.0",
    "express": "^5.2.1",
    "highlight.js": "11.11.1",
    "jsonwebtoken": "9.0.3",
    "jwt-decode": "^4.0.0",
    "ngx-datex": "1.0.5",
    "ngx-toastr": "^20.0.5",
    "rxjs": "^7.8.2",
    "sweetalert2": "^11.26.21",
    "tabulator-tables": "^6.3.1",
    "tslib": "^2.8.1",
    "uuid": "13.0.0",
    "zone.js": "0.16.1",
    "ngx-permissions": "^19.0.0",
    "ngx-progressbar": "^14.0.0",
    "screenfull": "^6.0.2",
    "rollup": "4.62.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.2",
    "@angular-devkit/schematics": "22.0.2",
    "@angular/build": "22.0.2",
    "@angular/cli": "22.0.2",
    "@angular/compiler-cli": "22.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "30.2.0",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/rollup": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.58.2",
    "@schematics/angular": "22.0.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.3.5",
    "@types/tabulator-tables": "^6.3.1",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/utils": "^8.56.1",
    "@vitest/ui": "4.0.18",
    "ajv": "^8.18.0",
    "angular-eslint": "21.3.0",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "2.10.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-environment-node": "^30.2.0",
    "jest-preset-angular": "16.1.1",
    "jest-util": "30.2.0",
    "jiti": "2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "16.3.2",
    "ng-packagr": "22.0.0",
    "nx": "23.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.97.3",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.2",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.56.1",
    "verdaccio": "6.7.4",
    "vite": "8.1.0",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "less",
      "lmdb",
      "msgpackr-extract",
      "nx",
      "rollup",
      "unrs-resolver"
    ],
    "overrides": {
      "qs": ">=6.14.1"
    }
  },
  "lint-staged": {
    "*.{ts,js,html,css,scss,json,md}": [
      "prettier --write"
    ],
    "*.{ts,js}": [
      "nx run-many --target=lint --files"
    ]
  },
  "nx": {
    "includedScripts": []
  }
}
