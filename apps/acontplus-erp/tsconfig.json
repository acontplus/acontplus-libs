{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedModules": true,
    "module": "preserve",
    "baseUrl": "./",
    "paths": {
      "@acontplus/core": ["../../packages/core/src/index.ts"],
      "@acontplus/ng-auth": ["../../packages/ng-auth/src/index.ts"],
      "@acontplus/ng-components": ["../../packages/ng-components/src/index.ts"],
      "@acontplus/ng-config": ["../../packages/ng-config/src/index.ts"],
      "@acontplus/ng-customer": ["../../packages/ng-customer/src/index.ts"],
      "@acontplus/ng-infrastructure": ["../../packages/ng-infrastructure/src/index.ts"],
      "@acontplus/ng-notifications": ["../../packages/ng-notifications/src/index.ts"],
      "@acontplus/ui-kit": ["../../packages/ui-kit/src/index.ts"],
      "@acontplus/utils": ["../../packages/utils/src/index.ts"],
      "@acontplus/ng-common": ["../../packages/ng-common/src/index.ts"],
      "@core": ["src/app/core"],
      "@core/*": ["src/app/core/*"],
      "@shared": ["src/app/shared"],
      "@shared/*": ["src/app/shared/*"],
      "@theme": ["src/app/theme"],
      "@theme/*": ["src/app/theme/*"],
      "@env": ["src/environments"],
      "@env/*": ["src/environments/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
